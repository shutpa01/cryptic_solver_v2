# Databases
*.db

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
.venv/
*.egg-info/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Scratch/temp
scratch.py

# Environment
.env

# Data archives
*.zip

# Logs
*.log

# Scraper debug artifacts only (JSON puzzle data IS tracked)

# Scraper debug artifacts
scraper/*/*.html
scraper/*/*.png

# Persistent browser profiles
.chrome_profile/
.firefox_profile/
scraper/*/.firefox_profile/

# FT scraped PDFs
scraper/FT/ft_pdfs/

# Tailwind generated CSS
web/static/css/app.css

# Local DB backups (created during refactors)
*.db.bak*

# Scraper progress/state files (regenerated each run, not puzzle data)
scraper/*/*_progress.json
scraper/*/*_state.json

# Generated review artifacts (regenerated by collect_for_review.py)
data/claude_review_*.txt

# Generated analysis outputs (regenerated by detect_*/reverify_* scripts)
data/positional_lie_suspects.txt
data/synonym_phrase_suspects.txt
data/demoted_last_week.txt
data/candidate_definition_pairs.jsonl
data/cohorts/

# Pipeline puzzle reports (generated per run)
documents/pending_gaps_*.json
documents/puzzle_report_*.txt
documents/puzzle_report_*.json

# Local analytics + setup artefacts (contain credentials, not source)
impressions/

# Memory leaked into project root (real memory lives in ~/.claude/...)
memory/session_*.md

# Office docs / drafts (synced separately)
*.docx
cryptic_taxonomy/

# SQLite working files (regenerated by sqlite engine)
*.db-shm
*.db-wal

# Recovery + safety backups (created during file recovery / refactors)
*.bad_session_backup
*.before_*
*.backup_pre_*
_recovery_*/

# Root-level scratch / test scripts (one-off, not part of the project)
/_test_*.py
/_audit_*.py

# Claude Code session state (per-project memory + lock files)
.claude/projects/
.claude/scheduled_tasks.lock

# Per-puzzle one-off scripts (use the dashboard pipeline runner instead)
/scripts/dm[0-9]*.py
/scripts/dt[0-9]*.py
/scripts/g[0-9]*.py
/scripts/guardian[0-9]*.py
/scripts/indy[0-9]*.py
/scripts/times[0-9]*.py

# Scratch data (underscore prefix marks throwaway)
/data/_*

# Timestamped change/delete logs (one-off audit artefacts)
/data/*_20[0-9][0-9][0-9][0-9][0-9][0-9]_*.jsonl

# One-off verifier comparison snapshots (baselines are kept, comparisons are not)
/data/verifier_after_change*.json
